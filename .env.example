# Base URL without path, e.g. https://mm.2gis.one
MATTERMOST_URL=https://mm.2gis.one
# Optional; default 443 for https, 8065 for http
# MATTERMOST_PORT=443
BOT_TOKEN=
# Необязательно: если пусто, бот берёт свой id из API после логина
BOT_ID=
# Для корпоративного TLS без корневого CA в системе: false (только для доверенной сети)
# MATTERMOST_SSL_VERIFY=false
# Либо путь к PEM с вашим CA (проверка включена): MATTERMOST_SSL_CA_FILE=/path/to/ca.pem

# Jira: команда /agree в треде (только автор раунда)
# JIRA_TOKEN=
# JIRA_BASE_URL=https://jira.2gis.ru
# JIRA_STORY_POINTS_FIELD=customfield_10080
# JIRA_HOURS_PER_SP=6
# JIRA_SSL_VERIFY=true
# JIRA_SSL_CA_FILE=
